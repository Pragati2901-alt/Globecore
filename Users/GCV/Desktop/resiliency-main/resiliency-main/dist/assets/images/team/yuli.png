dcee75 e-flex e-con-boxed e-con e-parent nitro-lazy"> <div class="e-con-inner"> <div class="elementor-element elementor-element-af993e5 e-con-full e-flex e-con e-child" data-id="af993e5" data-element_type="container" data-e-type="container"> <div class="elementor-element elementor-element-fff07c9 e-con-full e-flex e-con e-child" data-id="fff07c9" data-element_type="container" data-e-type="container"> <div class="elementor-element elementor-element-5ff7945 elementor-widget elementor-widget-heading" data-id="5ff7945" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"> <div class="elementor-widget-container"> <h6 class="elementor-heading-title elementor-size-default">Feel Better. Live Better. </h6> </div> </div> <div class="elementor-element elementor-element-71bcfa9 elementor-widget elementor-widget-heading" data-id="71bcfa9" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"> <div class="elementor-widget-container"> <h1 class="elementor-heading-title elementor-size-default">Transformative Mental Health &amp; TMS Therapy in Orange County</h1> </div> </div> <div class="elementor-element elementor-element-1ee9cf7 elementor-widget elementor-widget-text-editor" data-id="1ee9cf7" data-element_type="widget" data-e-type="widget" data-widget_type="text-editor.default"> <div class="elementor-widget-container"> <p class="" data-start="409" data-end="777">At Resiliency Mind + Body Medicine, we specialize in innovative, science-backed treatments for depression, anxiety, PTSD, and other mental health conditions. With convenient locations in Newport Beach and San Juan Capistrano, our clinics offer Deep Transcranial Magnetic Stimulation (TMS), SPRAVATO® (esketamine), integrative psychiatry, and personalized medication management—all under the care of experienced, board-certified providers.</p> </div> </div> <div class="elementor-element elementor-element-81322cd e-con-full e-flex e-con e-child" data-id="81322cd" data-el